{
  "flux_version": 2,
  "target": "any",
  "entry_point": "main",
  "types": [
    {
      "id": "t_u8",
      "kind": "integer",
      "bits": 8,
      "signed": false
    },
    {
      "id": "t_u64",
      "kind": "integer",
      "bits": 64,
      "signed": false
    },
    {
      "id": "t_buf",
      "kind": "array",
      "element": "t_u8",
      "length": 12
    },
    {
      "id": "t_unit",
      "kind": "unit"
    }
  ],
  "regions": [
    {
      "id": "r_static",
      "lifetime": "static"
    },
    {
      "id": "r_main",
      "lifetime": "scoped",
      "scope": "main"
    }
  ],
  "nodes": [
    {
      "id": "n_msg",
      "kind": "C",
      "op": "CONST_BYTES",
      "value": [
        72,
        101,
        108,
        108,
        111,
        32,
        87,
        111,
        114,
        108,
        100,
        10
      ],
      "type_out": "t_buf",
      "region": "r_static"
    },
    {
      "id": "n_fd",
      "kind": "C",
      "op": "CONST",
      "value": 1,
      "type_out": "t_u64"
    },
    {
      "id": "n_len",
      "kind": "C",
      "op": "CONST",
      "value": 12,
      "type_out": "t_u64"
    },
    {
      "id": "n_write",
      "kind": "E",
      "op": "SYSCALL_WRITE",
      "inputs": [
        "n_fd",
        "n_msg",
        "n_len"
      ],
      "type_out": "t_u64",
      "effects": [
        "IO.stdout"
      ],
      "fault_policy": "abort",
      "faults": [
        "n_write_fault"
      ]
    },
    {
      "id": "n_write_fault",
      "kind": "F",
      "fault_type": "SYSCALL_ERROR",
      "source": "n_write",
      "recovery": "ABORT",
      "exit_code": 1
    },
    {
      "id": "n_exit_code",
      "kind": "C",
      "op": "CONST",
      "value": 0,
      "type_out": "t_u64"
    },
    {
      "id": "n_exit",
      "kind": "E",
      "op": "SYSCALL_EXIT",
      "inputs": [
        "n_exit_code"
      ],
      "type_out": "t_unit",
      "effects": [
        "PROCESS.exit"
      ]
    },
    {
      "id": "main",
      "kind": "K",
      "op": "SEQ",
      "sequence": [
        "n_write",
        "n_exit"
      ],
      "type_out": "t_unit"
    }
  ],
  "contracts": [
    {
      "id": "v_fd_valid",
      "target": "n_write",
      "pre": "n_fd.value == 1",
      "comment": "Schreibt auf stdout (fd 1)"
    },
    {
      "id": "v_len_matches",
      "target": "n_write",
      "pre": "n_len.value == n_msg.length",
      "comment": "Laengenangabe stimmt mit Buffer ueberein"
    }
  ]
}
